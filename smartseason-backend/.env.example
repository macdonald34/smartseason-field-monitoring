# Backend Configuration

# Server Port
PORT=5000

# MongoDB Connection
# Local: mongodb://localhost:27017/smartseason
# Atlas: mongodb+srv://username:password@cluster.mongodb.net/smartseason
MONGODB_URI=mongodb://localhost:27017/smartseason

# JWT Secret (change this to a strong random string in production)
JWT_SECRET=your_jwt_secret_key_here_change_in_production

# Environment
NODE_ENV=development
